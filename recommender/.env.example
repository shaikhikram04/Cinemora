PORT=8000

# Same local Mongo instance the Node backend uses. No auth enabled in local
# dev, so this connection is scoped by code discipline (read-only on
# users/libraryentries/rankinglists), not by a Mongo role. See plan doc for
# the real-RBAC follow-up once a staging/prod DB with auth exists.
MONGO_URI=mongodb://localhost:27017/watchary

REDIS_URL=redis://localhost:6379/0

# Reuse the same TMDB key as backend/.env
TMDB_API_KEY=your_tmdb_api_key_here

# Must match INTERNAL_SERVICE_SECRET in backend/.env — Node sends this on
# every proxied call so the recommender only accepts internal traffic.
INTERNAL_SERVICE_SECRET=change-me-shared-with-node-backend

# Daily catalog ingestion sweep time (UTC hour)
INGESTION_HOUR_UTC=3
# Pages pulled per TMDB/Jikan list during ingestion (~20-25 items/page)
CATALOG_PAGE_LIMIT=5

# Mood chat (Gemini-powered). Without a key, the mood endpoint returns 503.
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
# The free tier meters quota PER MODEL, and the good models get very little of
# it (gemini-3.5-flash: ~20 requests/day — one chat turn costs 2-3 requests).
# The fallback has its own separate daily budget, so the chat cascades to it
# when the primary is exhausted (429) or shedding load (503). Google no longer
# publishes the per-model numbers — check https://aistudio.google.com/rate-limit
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
MOOD_MAX_TURNS_PER_SESSION=8
MOOD_MAX_SESSIONS_PER_DAY=2
