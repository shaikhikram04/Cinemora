PORT=3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/watchary

# JWT secrets
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# TMDB API key (from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# Firebase service account (paste the full JSON as a single-line string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cloudinary — stores profile avatars and cover images.
# Copy verbatim from Cloudinary dashboard → Account Details → API environment variable.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Python recommender service (internal, not publicly exposed)
RECOMMENDER_URL=http://localhost:8000
# Must match INTERNAL_SERVICE_SECRET in recommender/.env
INTERNAL_SERVICE_SECRET=change-me-shared-with-recommender

# Shared with the recommender service; cache is optional (fails open if down)
REDIS_URL=redis://localhost:6379/0
